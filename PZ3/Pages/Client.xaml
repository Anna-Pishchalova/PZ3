<Page x:Class="PZ3.Pages.Client"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PZ3.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Client" Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Visibility="Hidden" x:Name="txtblockCaptcha" Text="Captcha:"/>
            <TextBox Visibility="Hidden" x:Name="txtboxCaptcha"/>
            <TextBlock HorizontalAlignment="Center" Visibility="Hidden" x:Name="txtBlockTimer"/>
            <StackPanel Orientation="Horizontal" Height="80" HorizontalAlignment="Center"/>
        </StackPanel>
        <Grid Grid.Row="0" Background="#e8c5c5" Grid.ColumnSpan="3" Margin="0,0,0,390">
            <Button x:Name="btnBack" HorizontalAlignment="Right" Content="Exit" Click="btnBack_Click"/>
            <Image Width="205" HorizontalAlignment="Left" Margin="26,5,0,5" Stretch="None" Source="/Resources/logo.png"/>
        </Grid>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Margin="70,68,0,0" TextWrapping="Wrap" Text="Welcome back!" VerticalAlignment="Top" Width="144" Height="25" RenderTransformOrigin="0.5,0.5" FontSize="18" SelectionOpacity="0" UndoLimit="97" BorderThickness="0,0,0,0">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.227"/>
                    <TranslateTransform/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
    </Grid>
</Page>
